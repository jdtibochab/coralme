{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "coralME",
  "description": "JSON representation of a COBRA ME-model",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "default": 1
    },
    "annotation": {
      "type": "object"
    },
    "notes": {
      "type": "object"
    },
    "global_info": {
      "$ref": "#/$defs/global_info"
    },
    "metabolites": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/metabolite"
      }
    },
    "process_data": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/process_data"
      }
    },
    "reactions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reaction"
      }
    }
  },
  "required": [
    "global_info",
    "metabolites",
    "process_data",
    "reactions"
  ],
  "unevaluatedProperties": true,
  "$defs": {
    "nullable_string": {
      "type": ["string", "null"]
    },
    "nullable_number": {
      "type": ["number", "null"]
    },
    "reaction_bound": {
      "type": ["number", "string"]
    },
    "number_dict": {
      "type": "object",
      "patternProperties": {
        ".*": {
          "type": "number"
        }
      },
      "unevaluatedProperties": false
    },
    "string_number_dict": {
      "type": "object",
      "patternProperties": {
        ".*": {
          "type": ["string", "number"]
        }
      },
      "unevaluatedProperties": false
    },
    "global_info": {
      "type": "object",
      "properties": {
        "GC_fraction":        { "type": "number" },
        "f_mRNA":             { "type": "number" },
        "f_rRNA":             { "type": "number" },
        "f_tRNA":             { "type": "number" },
        "k_deg":              { "type": "number" },
        "kt":                 { "type": "number" },
        "m_aa":               { "type": "number" },
        "m_nt":               { "type": "number" },
        "m_rr":               { "type": "number" },
        "m_tRNA":             { "type": "number" },
        "propensity_scaling": { "type": "number" },
        "r0":                 { "type": "number" },
        "temperature":        { "type": "number" }
      },
      "unevaluatedProperties": true
    },
    "base_metabolite": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "formula": {
          "$ref": "#/$defs/nullable_string"
        },
        "compartment": {
          "$ref": "#/$defs/nullable_string"
        },
        "charge": {
          "$ref": "#/$defs/nullable_number"
        },
        "_bound": {
          "type": "number",
          "default": 0
        },
        "_constraint_sense": {
          "type": "string",
          "pattern": "^(E|L|G)$",
          "default": "E"
        },
        "annotation": {
          "type": "object"
        },
        "notes": {
          "type": "object"
        }
      },
      "required": [
        "id"
      ]
    },
    "metabolite": {
      "allOf": [
        {
          "$ref": "#/$defs/base_metabolite"
        },
        {
          "type": "object",
          "properties": {
            "metabolite_type": {
              "oneOf": [
                { "$ref": "#/$defs/Metabolite" },
                { "$ref": "#/$defs/TranslatedGene" },
                { "$ref": "#/$defs/ProcessedProtein" },
                { "$ref": "#/$defs/Complex" },
                { "$ref": "#/$defs/Ribosome" },
                { "$ref": "#/$defs/GenericComponent" },
                { "$ref": "#/$defs/GenerictRNA" },
                { "$ref": "#/$defs/RNAP" },
                { "$ref": "#/$defs/Constraint" },
                { "$ref": "#/$defs/TranscribedGene" }
              ]
            }
          },
          "required": [
            "metabolite_type"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "Metabolite": {
      "type": "object",
      "properties": {
        "type": {
          "const": "Metabolite"
        }
      },
      "required": [
        "type"
      ]
    },
    "TranslatedGene": {
      "type": "object",
      "properties": {
        "type": {
          "const": "TranslatedGene"
        }
      },
      "required": [
        "type"
      ]
    },
    "ProcessedProtein": {
      "type": "object",
      "properties": {
        "type": {
          "const": "ProcessedProtein"
        },
        "unprocessed_protein_id": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "unprocessed_protein_id"
      ]
    },
    "Complex": {
      "type": "object",
      "properties": {
        "type": {
          "const": "Complex"
        }
      },
      "required": [
        "type"
      ]
    },
    "Ribosome": {
      "type": "object",
      "properties": {
        "type": {
          "const": "Ribosome"
        }
      },
      "required": [
        "type"
      ]
    },
    "GenericComponent": {
      "type": "object",
      "properties": {
        "type": {
          "const": "GenericComponent"
        }
      },
      "required": [
        "type"
      ]
    },
    "GenerictRNA": {
      "type": "object",
      "properties": {
        "type": {
          "const": "GenerictRNA"
        }
      },
      "required": [
        "type"
      ]
    },
    "RNAP": {
      "type": "object",
      "properties": {
        "type": {
          "const": "RNAP"
        }
      },
      "required": [
        "type"
      ]
    },
    "Constraint": {
      "type": "object",
      "properties": {
        "Constraint": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "TranscribedGene": {
      "type": "object",
      "properties": {
        "type": {
          "const": "TranscribedGene"
        },
        "RNA_type": {
          "type": "string",
          "pattern": "^(mRNA|rRNA|tRNA|ncRNA|tmRNA|.*RNA)$"
        },
        "nucleotide_sequence": {
          "type": "string"
        },
        "left_pos": {
          "type": ["string", "null", "array"]
        },
        "right_pos": {
          "type": ["string", "null", "array"]
        },
        "strand": {
          "type": ["string", "null"],
          "pattern": "^(\\+|-)$"
        }
      },
      "required": [
        "type",
        "RNA_type",
        "nucleotide_sequence",
        "left_pos",
        "right_pos",
        "strand"
      ]
    },
    "reaction_base": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "metabolites": {
          "$ref": "#/$defs/string_number_dict"
        },
        "lower_bound": {
          "$ref": "#/$defs/reaction_bound"
        },
        "upper_bound": {
          "$ref": "#/$defs/reaction_bound"
        },
        "objective_coefficient": {
          "type": "number",
          "default": 0
        },
        "variable_kind": {
          "type": "string",
          "pattern": "^continuous$",
          "default": "continuous"
        }
      },
      "required": [
        "id",
        "metabolites",
        "lower_bound",
        "upper_bound"
      ]
    },
    "reaction": {
      "allOf": [
        {
          "$ref": "#/$defs/reaction_base"
        },
        {
          "oneOf": [
            { "$ref": "#/$defs/MetabolicReaction" },
            { "$ref": "#/$defs/BoundaryReaction" },
            { "$ref": "#/$defs/ComplexFormation" },
            { "$ref": "#/$defs/ComplexDegradation" },
            { "$ref": "#/$defs/PostTranslationReaction" },
            { "$ref": "#/$defs/TranscriptionReaction" },
            { "$ref": "#/$defs/GenericFormationReaction" },
            { "$ref": "#/$defs/SummaryVariable" },
            { "$ref": "#/$defs/TranslationReaction" },
            { "$ref": "#/$defs/tRNAChargingReaction" },
            { "$ref": "#/$defs/rRNAFormationReaction" }
          ]
        }
      ],
      "unevaluatedProperties": true
    },
    "BoundaryReaction": {
      "type": "object",
      "properties": {
        "type": {
          "const": "BoundaryReaction"
        },
        "stoichiometric_data": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "stoichiometric_data"
      ]
    },
    "MetabolicReaction": {
      "type": "object",
      "properties": {
        "type": {
          "const": "MetabolicReaction"
        },
        "complex_data": {
          "$ref": "#/$defs/nullable_string"
        },
        "stoichiometric_data": {
          "type": "string"
        },
        "keff": {
          "type": "number"
        },
        "reverse": {
          "type": "boolean"
        }
      },
      "required": [
        "type",
        "stoichiometric_data"
      ]
    },
    "ComplexFormation": {
      "type": "object",
      "properties": {
        "type": {
          "const": "ComplexFormation"
        },
        "_complex_id": {
          "type": "string"
        },
        "complex_data_id": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "_complex_id",
        "complex_data_id"
      ]
    },
    "ComplexDegradation": {
      "type": "object",
      "properties": {
        "type": {
          "const": "ComplexDegradation"
        },
        "_complex_id": {
          "type": "string"
        },
        "complex_data_id": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "_complex_id",
        "complex_data_id"
      ]
    },
    "PostTranslationReaction": {
      "type": "object",
      "properties": {
        "type": {
          "const": "PostTranslationReaction"
        },
        "posttranslation_data": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "posttranslation_data"
      ]
    },
    "TranscriptionReaction": {
      "type": "object",
      "properties": {
        "type": {
          "const": "TranscriptionReaction"
        },
        "transcription_data": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "transcription_data"
      ]
    },
    "GenericFormationReaction": {
      "type": "object",
      "properties": {
        "type": {
          "const": "GenericFormationReaction"
        }
      },
      "required": [
        "type"
      ]
    },
    "rRNAFormationReaction": {
      "type": "object",
      "properties": {
        "type": {
          "const": "rRNAFormationReaction"
        }
      },
      "required": [
        "type"
      ]
    },
    "SummaryVariable": {
      "type": "object",
      "properties": {
        "SummaryVariable": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "TranslationReaction": {
      "type": "object",
      "properties": {
        "type": {
          "const": "TranslationReaction"
        },
        "translation_data": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "translation_data"
      ]
    },
    "tRNAChargingReaction": {
      "type": "object",
      "properties": {
        "type": {
          "const": "tRNAChargingReaction"
        },
        "tRNA_data": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "tRNA_data"
      ]
    },
    "process_data": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string"
        }
      },
      "required": [
        "id"
      ]
    }
  }
}